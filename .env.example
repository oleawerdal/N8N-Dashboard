# Set to "mock" to use built-in fake data (default), or "live" to call your n8n instance
N8N_MODE=mock

# Required when N8N_MODE=live
N8N_BASE_URL=https://n8n.yourdomain.com
N8N_API_KEY=eyJhbGciOi...

# Cookie session secret (must be at least 32 chars in production)
SESSION_SECRET=dev-secret-change-me-please-32chars+
