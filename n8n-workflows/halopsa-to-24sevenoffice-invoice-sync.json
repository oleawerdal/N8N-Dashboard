    {
      "parameters": {
        "jsCode": "// Normalize the HaloPSA client into a system-neutral customer object.\n// NOTE: Halo's org/VAT number field name varies per instance and was NOT\n// verifiable from the API libraries. Adjust the candidate fields below to\n// whatever your Halo tenant uses (check GET /api/Client/{id} in your Swagger).\nconst client = $input.first().json;\n\nconst orgNumber = String(\n  client.taxnumber ?? client.accountsid ?? client.vatnumber ?? client.registrationnumber ?? ''\n).replace(/\\s/g, '');\n\nreturn [\n  {\n    json: {\n      orgNumber,\n      name: client.name ?? '',\n      email: client.emailaddress ?? client.email ?? '',\n      phone: client.telephone ?? client.phonenumber ?? '',\n      address: client.address ?? '',\n      city: client.city ?? '',\n      postcode: client.postcode ?? '',\n      country: client.country ?? $('Config').first().json.defaultCountry,\n      haloClientId: client.id,\n    },\n  },\n];\n"
      },
      "id": "11111111-1111-1111-1111-111111111105",
      "name": "Normalize Customer",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 320]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $('Config').item.json.twentyFourApiBase }}/customers",
        "authentication": "genericCredentialType",
        "genericAuthType": "oAuth2Api",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "={{ $('Config').item.json.orgNumberQueryParam }}",
              "value": "={{ $('Normalize Customer').item.json.orgNumber }}"
            }
          ]
        },
        "options": {}
      },
      "id": "11111111-1111-1111-1111-111111111106",
      "name": "Find 24SO Customer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1100, 320],
      "credentials": {
        "oAuth2Api": {
          "id": "24so-oauth2",
          "name": "24SevenOffice OAuth2 (client credentials)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Match the Halo customer to an existing 24SO customer by organization number.\n// We filter in code (not just via the query param) so a wrong/ignored query\n// param can't cause a false 'no match'. The 24SO org-number field name is NOT\n// verified — adjust the candidate list below to your tenant's schema.\nconst res = $input.first().json;\nconst list = Array.isArray(res)\n  ? res\n  : (res.data ?? res.items ?? res.customers ?? res.value ?? res.results ?? []);\n\nconst digits = (s) => String(s ?? '').replace(/\\D/g, '');\nconst target = digits($('Normalize Customer').first().json.orgNumber);\n\nconst match = target\n  ? list.find((c) =>\n      [c.corporateId, c.organizationNumber, c.orgNumber, c.vatNumber, c.registrationNumber, c.organizationNo]\n        .some((v) => digits(v) && digits(v) === target)\n    )\n  : null;\n\nreturn [\n  {\n    json: {\n      matched: !!match,\n      customerId: match ? (match.id ?? match.customerId ?? match.customerNo ?? null) : null,\n      orgNumber: $('Normalize Customer').first().json.orgNumber,\n    },\n  },\n];\n"
      },
      "id": "11111111-1111-1111-1111-111111111107",
      "name": "Match Org Number",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1320, 320]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose",
            "version": 2
          },
          "conditions": [
            {
              "id": "cond-match",
              "leftValue": "={{ $json.matched }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
