# Set to "mock" to use built-in fake data (default), or "live" to call your n8n instance
N8N_MODE=mock

# Required when N8N_MODE=live
N8N_BASE_URL=https://n8n.yourdomain.com
N8N_API_KEY=eyJhbGciOi...

# Cookie session secret (must be at least 32 chars in production)
SESSION_SECRET=dev-secret-change-me-please-32chars+

# --- Persistence (Postgres) ---
# Set DATABASE_URL to make clients, users, admins and settings survive
# redeploys/restarts. Without it the app runs in-memory with demo data.
# DATABASE_URL=postgres://user:password@host:5432/dbname
# Set to "true" only if your Postgres requires TLS (most managed providers do;
# Coolify's internal Postgres usually does not).
# DATABASE_SSL=false

# --- Initial admin (only used to seed a fresh Postgres database) ---
# ADMIN_EMAIL=you@yourdomain.com
# ADMIN_NAME=Your Name
# ADMIN_PASSWORD=change-me-please
