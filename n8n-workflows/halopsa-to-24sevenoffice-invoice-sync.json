        "url": "={{ $('Config').item.json.twentyFourApiBase }}/salesOrders/{{ $('Build Lines').item.json.orderId }}/lines",
        "authentication": "genericCredentialType",
        "genericAuthType": "oAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($('Build Lines').item.json.lines) }}",
