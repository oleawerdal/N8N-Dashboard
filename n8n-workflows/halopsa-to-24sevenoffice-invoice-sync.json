    {
      "parameters": {
        "jsCode": "// Map Halo invoice lines → 24SO sales-order lines and resolve the new order id.\n// Both the Halo line field names and the 24SO line field names are NOT verified\n// — adjust the mappings to match your two instances.\nconst inv = $('Get Halo Invoice').first().json;\nconst cfg = $('Config').first().json;\nconst order = $('Create Sales Order').first().json;\n\nconst orderId = order.id ?? order.orderId ?? order.salesOrderId ?? order.Id;\nconst haloLines = inv.lines ?? inv.invoicelines ?? [];\n\nconst lines = haloLines.map((l) => ({\n  description: l.description ?? l.detail ?? l.item ?? '',\n  productId: l.product_id ?? l.productid ?? null,\n  quantity: Number(l.quantity ?? l.qty ?? 1),\n  price: Number(l.unitprice ?? l.unit_price ?? l.baseprice ?? l.price ?? 0),\n  discountRate: Number(l.discount ?? l.discountrate ?? 0),\n  taxCode: l.taxcode ?? l.tax_code ?? cfg.defaultTaxCode,\n}));\n\nreturn [{ json: { orderId, lines } }];\n"
      },
      "id": "11111111-1111-1111-1111-111111111113",
      "name": "Build Lines",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2460, 320]
    },
